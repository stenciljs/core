{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "style": "off",
    "perf": "warn"
  },
  "rules": {
    "no-cond-assign": "error",
    "no-var": "error",
    "prefer-const": "error",
    "prefer-rest-params": "error",
    "prefer-spread": "error",
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^(h|Fragment)$"
      }
    ]
  },
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "**/dist/**",
    "**/*.d.ts"
  ]
}
