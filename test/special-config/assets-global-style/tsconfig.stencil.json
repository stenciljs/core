{
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "@stencil/core",
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "rootDir": "./"
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/*.e2e.ts"]
}
