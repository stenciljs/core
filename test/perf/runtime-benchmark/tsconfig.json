{
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "lib": ["dom", "es2017"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2022",
    "jsx": "react-jsx",
    "jsxImportSource": "@stencil/core",
    "rootDir": "./"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
