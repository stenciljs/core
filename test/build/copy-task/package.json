{
  "name": "@stencil-core-tests/build-copy-task",
  "version": "0.0.2-alpha.0",
  "description": "Stencil Component Starter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "unpkg": "dist/copytask/copytask.esm.js",
  "exports": {
    ".": {
      "import": "./dist/copytask/copytask.esm.js",
      "require": "./dist/copytask/copytask.cjs.js"
    },
    "./my-component": {
      "import": "./dist/components/my-component.js",
      "types": "./dist/components/my-component.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf ./dist && stencil build",
    "test": "npm run build && node validate.js"
  },
  "dependencies": {
    "@stencil/core": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "vitest": "catalog:"
  },
  "volta": {
    "extends": "../../../package.json"
  },
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js"
}
