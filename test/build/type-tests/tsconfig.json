{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["dom", "ES2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "@stencil/core",
    "experimentalDecorators": true,
    "rootDir": "./",
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "include": ["src", "test.spec.tsx"]
}
