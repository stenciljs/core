{
  "compilerOptions": {
    "declaration": false,
    "strictPropertyInitialization": false,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "@stencil/core",
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "rootDir": "./",
    "types": ["@stencil/vitest/globals"],
    "paths": {
      "@path-alias": ["./src/components/build/path-alias-cmp/path-alias-lib"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/*.spec.ts", "src/**/*.spec.tsx"]
}
