    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "pretty": true,
    "target": "es2017",
    "useUnknownInCatchVariables": true,
    "rootDir": ".",
    "paths": {
      "@path-alias": ["./src/path-alias-cmp/path-alias-lib"]
    }
  },
  "include": ["src"]
