{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": ["test/**"],
  "ignoreBinaries": ["playwright"],
  "workspaces": {
    "packages/core": {
      "entry": ["src/testing/app-data.ts", "build/version-utils.ts"],
      "ignore": ["src/index.d.mts", "src/**/_test_/**"],
      "ignoreDependencies": ["vitest-environment-stencil"]
    },
    "packages/cli": {},
    "packages/mock-doc": {},
    "packages/dev-server": {
      "ignore": ["src/server/worker-thread.js", "src/**/_test_/**"],
      "ignoreDependencies": ["vitest-environment-stencil"]
    }
  }
}
