{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": ["test/**"],
  "ignoreBinaries": ["playwright"],
  "workspaces": {
    "packages/core": {
      "entry": ["src/testing/app-data.ts", "build/version-utils.ts", "src/index.d.mts"],
      "ignore": ["src/**/_test_/**", "src/server/runner/hydrate-factory.ts", "src/testing/platform/**"],
      "ignoreDependencies": ["vitest-environment-stencil"],
      "ignoreUnresolved": ["virtual:*"]
    },
    "packages/cli": {},
    "packages/mock-doc": {},
    "packages/dev-server": {
      "ignore": ["src/server/worker-thread.js", "src/**/_test_/**"],
      "ignoreDependencies": ["vitest-environment-stencil"]
    }
  }
}
